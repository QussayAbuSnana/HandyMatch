rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile avatars — owner can read/write their own folder
    match /avatars/{userId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Review photos — any signed-in user can attach photos to a review; the
    // Firestore review-creation rules are what actually gate a valid review.
    match /reviews/{bookingId}/{fileName} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
