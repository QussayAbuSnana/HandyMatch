rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────────
    // Any signed-in user can read profiles (needed for search & pro detail page).
    // Only the owner can write their own document.
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Bookings ───────────────────────────────────────────────────────────────
    // Only the customer or the professional in the booking can read/update it.
    // Only the customer can create a booking (they set their own customerId).
    match /bookings/{bookingId} {
      allow read, update: if request.auth != null && (
        resource.data.customerId    == request.auth.uid ||
        resource.data.professionalId == request.auth.uid
      );
      allow create: if request.auth != null &&
        request.resource.data.customerId == request.auth.uid;
    }

    // ── Conversations ──────────────────────────────────────────────────────────
    // Both participants can read & update the conversation document.
    // Any authenticated user can create a conversation (they must be a participant).
    match /conversations/{convId} {
      allow read, update: if request.auth != null &&
        request.auth.uid in resource.data.participants;
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;

      // Messages sub-collection: participants only
      match /messages/{msgId} {
        allow read: if request.auth != null &&
          request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if request.auth != null &&
          request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convId)).data.participants &&
          request.resource.data.senderId == request.auth.uid;
      }
    }

    // ── Booking slot locks ────────────────────────────────────────────────────
    // One doc per professional per hour-bucket a booking occupies (id: `{proId}_{hourBucket}`).
    // Used inside a transaction to atomically prevent two overlapping bookings for the same pro.
    match /bookingSlots/{slotId} {
      allow read, create, delete: if request.auth != null;
    }

    // ── Reviews ────────────────────────────────────────────────────────────────
    // Any signed-in user can read reviews (shown on pro profile).
    // Doc id is deterministic (`{bookingId}_{reviewerId}`), so a second submission for the
    // same booking+reviewer is an `update` — and since no `allow update` exists, it's denied
    // automatically, which is our duplicate-review guard.
    // A create must reference a real, completed booking where the reviewer and subject are
    // genuinely the two parties on that booking — you can't fabricate a review for a booking
    // that never happened, never completed, or that you weren't part of.
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.reviewerId == request.auth.uid &&
        reviewId == request.resource.data.bookingId + '_' + request.auth.uid &&
        get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.status == "completed" &&
        (
          (request.resource.data.type == "customer_to_pro" &&
           get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.customerId == request.auth.uid &&
           get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.professionalId == request.resource.data.subjectId)
          ||
          (request.resource.data.type == "pro_to_customer" &&
           get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.professionalId == request.auth.uid &&
           get(/databases/$(database)/documents/bookings/$(request.resource.data.bookingId)).data.customerId == request.resource.data.subjectId)
        );
    }

    // ── Notifications ──────────────────────────────────────────────────────────
    // Any authenticated user can create a notification (pros notify customers and vice versa).
    // Only the owner can read and update (mark as read) their own notifications.
    match /notifications/{notifId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }
  }
}
